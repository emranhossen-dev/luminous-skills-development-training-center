# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luminous_dev
DB_USER=postgres
DB_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Application Configuration
NODE_ENV=development
# Public URL of this app (no trailing slash). Required for bKash callbackURL.
# Local testing: use ngrok/cloudflared HTTPS URL so bKash can redirect back.
APP_URL=http://localhost:3000
PORT=3000

# Manual bKash instructions on enrollment page (shown to students)
NEXT_PUBLIC_MANUAL_BKASH_NUMBER=01XXXXXXXXX

# bKash Tokenized Checkout (hosted page, mode 0011) — use sandbox while testing
# Public sandbox test credentials (rotate to your merchant credentials in production)
BKASH_API_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=4f6o0cjiki2rfm34kfdadl1eqq
BKASH_APP_SECRET=2is7hdktrekvrbljjh44ll3d9l1dtjo4pasmjvs5vl5qr3fug4b
BKASH_USERNAME=sandboxTokenizedUser02
BKASH_PASSWORD=sandboxTokenizedUser02@12345
# Optional: default MSISDN pre-filled on bKash page if user has no phone on file (sandbox test number)
BKASH_SANDBOX_PAYER_MSISDN=01770618575

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR=uploads

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000
